# ── AWS ────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1

# ── Bedrock (LLM) ─────────────────────────────────────────────────────────────
AWS_BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# ── DynamoDB ──────────────────────────────────────────────────────────────────
DYNAMODB_REGION=ap-south-1

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_REGION=ap-south-1
S3_BUCKET_NAME=your-bucket-name

# ── Amazon Cognito ────────────────────────────────────────────────────────────
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=your_client_id_here

# ── Amazon SES ────────────────────────────────────────────────────────────────
SES_REGION=ap-south-1
SES_FROM_EMAIL=kiro@your-domain.com

# ── App ───────────────────────────────────────────────────────────────────────
# Production frontend URL (used in email links)
APP_URL=https://your-domain.com

# Comma-separated list of allowed CORS origins (production only)
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Rate limit for /api/chat and /api/transcribe (requests per minute per user)
# RATE_LIMIT_PER_MINUTE=30
